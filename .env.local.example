# Copy to .env.local and fill in values

# Anthropic — for script + caption generation
ANTHROPIC_API_KEY=sk-ant-...

# HeyGen — for video generation
# Get API key: heygen.com → Settings → API
HEYGEN_API_KEY=
# Your avatar ID — from heygen.com → Avatars (copy the ID of your Elias avatar)
HEYGEN_AVATAR_ID=
# Voice ID — from heygen.com → Voices (pick a calm, slightly deep male voice)
# Recommended: search for "Matthew" or "Daniel" or any deep/calm male voice
HEYGEN_VOICE_ID=

# Email platform (ConvertKit example — for landing page opt-in)
CONVERTKIT_API_KEY=
CONVERTKIT_FORM_ID=

# Stripe — for $37 purchase
STRIPE_SECRET_KEY=sk_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_...
STRIPE_WEBHOOK_SECRET=whsec_...
